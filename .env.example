# Adal Jumys — орта айнымалылары (ҮЛГІ)
# Көшіріп алу: cp .env.example .env
# ⚠️ .env ЕШҚАШАН коммитке түспейді (.gitignore-да). Мұнда тек плейсхолдер.

# ── Орта ──────────────────────────────────────────────
ENVIRONMENT=development

# ── PostgreSQL ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://adal:change-me@localhost:5432/adal_jumys

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────
# Генерациялау: openssl rand -hex 32
SECRET_KEY=change-me-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── S3-үйлесімді қойма (дәлел-файлдар) ────────────────
# STORAGE_BACKEND=local болса дискіге жазады (dev), s3 болса төмендегі конфиг керек
STORAGE_BACKEND=local
S3_ENDPOINT_URL=https://s3.example.com
S3_REGION=auto
S3_BUCKET=adal-jumys-evidence
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me

# ── Компания-реестр lookup (бос болса өшірулі) ────────
REGISTRY_API_URL=
REGISTRY_API_KEY=
